################################################################################
# MLSuite - Environment Configuration
# This is the default development configuration with HTTPS/TLS enabled
# For production, use .env.production
# For local overrides, use .env.local (NOT committed to git)
################################################################################

# ============================================================================
# Database Configuration
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_PROD=mlsuite_db
DB_TEST=mlsuite_db_test
DB_USER=mlsuite
DB_PASS=psql17mlsuite

# ============================================================================
# Service Ports - All using HTTPS/TLS
# ============================================================================
SPRING_PORT=8443
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000
WEB_PORT=5173
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_ADDRESS=:9001

# ============================================================================
# Spring Boot Configuration - HTTPS Enabled
# ============================================================================
SPRING_PROFILES_ACTIVE=prod
LOG_PATH=/var/log
CORS_ALLOW_ORIGINS=https://localhost:5173,https://localhost:8443
OPS_AGENT_BASE_URL=http://ops-agent:8091
OPS_AGENT_SHARED_SECRET=mlsuite-dev-secret
# SSL Configuration
SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=classpath:keystore-local.p12
SERVER_SSL_KEY_STORE_PASSWORD=changeit
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=mlsuite-local

# ============================================================================
# Superadmin seed
MLSUITE_SUPERADMIN_EMAIL=admin@example.com
MLSUITE_SUPERADMIN_PASSWORD=change_me_superadmin
MLSUITE_SUPERADMIN_FULL_NAME=MLSuite Admin
MLSUITE_SUPERADMIN_USERNAME=admin

# ============================================================================
# Backend (Python/FastAPI) Configuration - HTTPS Enabled
# ============================================================================
ANALYZER_BASE_URL=https://py-analyzer:8000
PYTHON_SSL_ENABLED=true
PYTHON_SSL_KEYFILE=/app/private.key
PYTHON_SSL_CERTFILE=/app/certificate.crt

# ============================================================================
# Frontend (React/Vite) Configuration - HTTPS Enabled
# ============================================================================
VITE_BACKEND_URL=

# ============================================================================
# Ops Agent Configuration
# ============================================================================
OPS_AGENT_HOST=0.0.0.0
OPS_AGENT_PORT=8091
OPS_AGENT_DOCKER_BIN=/usr/bin/docker
OPS_AGENT_MANAGED_SERVICES=postgres,py-analyzer,minio,spring-app,frontend
OPS_AGENT_SAMPLE_INTERVAL_SECONDS=5
OPS_AGENT_RETENTION_MINUTES=60
OPS_AGENT_TERMINAL_IDLE_MINUTES=15
OPS_AGENT_TERMINAL_MAX_SESSIONS=10
OPS_AGENT_LOG_TAIL_LINES=200

# ============================================================================
# Docker Registry Configuration (for production docker-compose)
# ============================================================================
REGISTRY=ghcr.io
OWNER=ulloasp

# Image names and versions
FRONTEND_IMAGE=mlsuite-frontend
FRONTEND_VERSION=latest

API_IMAGE=mlsuite-api
API_VERSION=latest

BACKEND_IMAGE=mlsuite-sklearn-backend
BACKEND_VERSION=latest

OPS_AGENT_IMAGE=mlsuite-ops-agent
OPS_AGENT_VERSION=latest

# Object Storage (MinIO)
STORAGE_ENABLED=true
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change_me_minio
STORAGE_BUCKET=mlsuite-models
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_BACKFILL_ON_STARTUP=true
